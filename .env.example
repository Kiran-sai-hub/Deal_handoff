# ─────────────────────────────────────────────────────────────────────────────
# Deal Handoff Agent — Environment Variables
#
# These are OPTIONAL bootstrap overrides only.
# All credentials and settings are configured through the Setup Wizard UI
# at http://localhost:8000/ui after running `docker compose up`.
# ─────────────────────────────────────────────────────────────────────────────

# Where SQLite stores deal data and config (default: ./data/deals.db inside container)
SQLITE_DB_PATH=/app/data/deals.db

# Your public-facing URL (shown in the Setup Wizard as the webhook URL to paste into CRMs)
APP_BASE_URL=http://localhost:8000
